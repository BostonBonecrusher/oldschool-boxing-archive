# ============================================================
# BOXING ARCHIVE — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file, rename the copy to .env, and fill in values.
# NEVER share your .env file or commit it to GitHub.
# ============================================================

# --- WEAVIATE CLOUD ---
# Your cluster URL from console.weaviate.cloud
# Example: https://my-boxing-archive.weaviate.network
WEAVIATE_URL=https://YOUR-CLUSTER-URL-HERE.weaviate.network

# Your Weaviate API key (Admin key from the API Keys section)
WEAVIATE_API_KEY=your-weaviate-api-key-here

# --- OPENAI ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- PDF SOURCE FOLDER ---
# Where your boxing PDFs are stored
PDF_FOLDER=C:\Users\tatte\OneDrive\Boxing_books

# --- TESSERACT PATH ---
# Where Tesseract OCR installed on your PC
# Default Windows install location:
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- POPPLER PATH ---
# The "bin" folder inside where you extracted Poppler
# Example: C:\poppler\poppler-24.08.0\Library\bin
POPPLER_PATH=C:\poppler\poppler-24.08.0\Library\bin

# --- WEB APP ---
# Password to access the web app (share this with people you invite)
APP_PASSWORD=your-password-here

# Secret key for session security — make this a long random string
# You can use anything, e.g.: boxing-archive-oldschool-gladiators-2025
FLASK_SECRET_KEY=change-this-to-something-random

# --- INGESTION SETTINGS (you can leave these as-is) ---
# How many characters per chunk (roughly 400 words)
CHUNK_SIZE=1500

# How many characters overlap between chunks (so context isn't lost at edges)
CHUNK_OVERLAP=200
